# Copy this file to .env.local and fill in real values.
# Never commit .env.local to GitHub.

# ─── Supabase (required for production) ───────────────────────────────────────
# https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# One-time DB setup: run supabase/schema.sql in the Supabase SQL Editor

# ─── Admin Panel (required) ───────────────────────────────────────────────────
ADMIN_PASSWORD=your-secure-password
# Generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-signing-key-minimum-32-characters

# ─── Email — Resend (optional, for quote notifications) ───────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=quotes@yourdomain.com
QUOTE_NOTIFY_EMAIL=airwavescomfort33@gmail.com

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
