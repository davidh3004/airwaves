# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Admin Panel ──────────────────────────────────────────────────────────────
# Password used to log in to /admin
ADMIN_PASSWORD=your-secure-password
# Random 32+ char string for signing session JWTs
JWT_SECRET=your-super-secret-jwt-signing-key-minimum-32-characters

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_resend_api_key
# The verified domain/email to send FROM (must be verified in Resend)
RESEND_FROM_EMAIL=quotes@yourdomain.com
# Where quote request notifications get delivered
QUOTE_NOTIFY_EMAIL=airwavescomfort33@gmail.com

# ─── Next.js ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
